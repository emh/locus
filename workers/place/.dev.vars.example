# Optional. If set, the browser sends this as a Bearer token.
APP_TOKEN=""

# Keep these aligned with the frontend dev server.
ALLOWED_ORIGINS="http://localhost:8020,http://127.0.0.1:8020"
GEOCODE_WORKER_URL="http://localhost:8799"

# Set true for local development without OpenAI.
MOCK_LLM="true"

# Set these when MOCK_LLM is false.
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-5"
OPENAI_REASONING_EFFORT="low"
